{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp@latest"],
      "env": {}
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${PWD}"
      ]
    },
    "postgres": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "${DATABASE_URL}"],
      "env": {
        "DATABASE_URL": "${DATABASE_URL}"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(pnpm:*)", "Bash(npx:*)", "Bash(npm:*)", "Bash(node:*)",
      "Bash(python3:*)", "Bash(pip3:*)", "Bash(uv:*)", "Bash(uvx:*)",
      "Bash(git:*)", "Bash(uvicorn:*)", "Bash(modal:*)",
      "Bash(find:*)", "Bash(grep:*)", "Bash(ls:*)", "Bash(mkdir:*)",
      "Bash(cp:*)", "Bash(mv:*)", "Bash(rm:*)", "Bash(cat:*)",
      "Bash(curl:*)", "Bash(touch:*)", "Bash(chmod:*)"
    ]
  }
}
