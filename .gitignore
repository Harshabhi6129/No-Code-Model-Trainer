# --- Logs & Temp ---
*.log
*.tmp
*.cache

# Keep placeholder files (e.g., .gitkeep) but ignore everything else inside these runtime dirs
uploads/*
!uploads/.gitkeep
runs/*
!runs/.gitkeep
checkpoints/*
!checkpoints/.gitkeep
exports/*
!exports/.gitkeep
reports/*
!reports/.gitkeep
wandb/*
!wandb/.gitkeep
backend/data/hf_cache/
backend/.env
